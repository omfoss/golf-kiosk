{
  "name": "golf-kiosk",
  "version": "2.0.0",
  "description": "Kongsvingers Golfklubb – Multi-screen kiosk",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.0.0",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "socket.io": "^4.7.5",
    "uuid": "^13.0.0"
  }
}
